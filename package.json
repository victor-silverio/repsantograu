{
  "name": "repsantograu",
  "version": "1.0.0",
  "description": "![Azure Static Web Apps CI/CD](https://github.com/victor-silverio/repsantograu/actions/workflows/azure-static-web-apps-black-moss-0abb1d50f.yml/badge.svg) ![SEO Automation](https://github.com/victor-silverio/repsantograu/actions/workflows/update_seo.yml/badge.svg) ![Cloudflare Protection](https://img.shields.io/badge/Protected%20by-Cloudflare-orange?logo=cloudflare) ![Website Status](https://img.shields.io/website?url=https%3A%2F%2Fwww.repsantograu.online&label=Online&color=success)",
  "main": "sw.js",
  "scripts": {
    "dev": "tailwindcss -i ./src/styles/input.css -o ./styles.css --watch",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./styles.css --minify",
    "build:js": "terser src/js/script.js -o src/js/script.min.js -c -m",
    "build": "npm run build:css && npm run build:js",
    "build:dist": "npm run build && node scripts/build/build_dist.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-silverio/repsantograu.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/victor-silverio/repsantograu/issues"
  },
  "homepage": "https://github.com/victor-silverio/repsantograu#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "terser": "^5.47.1",
    "workbox-build": "^7.4.1"
  }
}
